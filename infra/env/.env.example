# Application
APP_ENV=development
APP_NAME=ai-hotspot-radar
APP_TIMEZONE=Asia/Shanghai
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
DATABASE_URL=postgresql+psycopg://root:your-password@localhost:5432/ai_hotspot_radar

# AI model provider
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
RELEVANCE_THRESHOLD=50
SOURCE_FETCH_LIMIT=20

# Optional X/Twitter source
X_API_BEARER_TOKEN=

# SMTP email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TO_EMAIL=
SMTP_USE_TLS=true

# Scheduler
SCHEDULER_ENABLED=false
CHECK_INTERVAL_MINUTES=60
DAILY_DIGEST_ENABLED=false
DAILY_DIGEST_HOUR=8

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
