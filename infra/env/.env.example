# Application
APP_ENV=development
APP_NAME=ai-hotspot-radar
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_hotspot_radar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# OpenAI
OPENAI_API_KEY=replace-me
OPENAI_MODEL=replace-me

# Resend
RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL=replace-me@example.com
RESEND_TO_EMAIL=replace-me@example.com

# News sources
NEWSAPI_API_KEY=replace-me

# X API
X_API_BEARER_TOKEN=replace-me
X_DEFAULT_WOEID=1
X_RECENT_SEARCH_WINDOW_DAYS=7
